# =====================================================================
# ⚙️  Enterprise AI Control Plane - Master Configuration File
# =====================================================================

# --- Kubernetes Namespace ---
NAMESPACE=control-plane

# --- Container Image Configurations ---
# Change to your local registry (e.g., localhost:5000) or registry DNS name on the master node
REGISTRY=localhost:5000
TAG=latest

# --- Database / Datastore Credentials ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres-secure-pass
POSTGRES_DB=ai_control_plane

REDIS_PASSWORD=redis-secure-pass

MINIO_ROOT_USER=minio-root
MINIO_ROOT_PASSWORD=minio-root-pass

# --- LLM Gateway Configurations ---
LLM_GATEWAY_URL=http://litellm:4000/v1
LLM_MODEL=llama2

# --- External LAN Physical Machines ---
# IP of the separate physical machine running Ollama on port 11434
OLLAMA_HOST_IP=192.168.1.50
