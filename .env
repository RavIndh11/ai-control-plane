# =====================================================================
# ⚙️  Enterprise AI Control Plane - Master Configuration File
# =====================================================================

# --- Kubernetes Namespace ---
NAMESPACE=control-plane

# --- Container Image Configurations ---
# Change to your local registry (e.g., localhost:5000) or registry DNS name on the master node
REGISTRY=localhost:5000
TAG=latest

# --- Database / Datastore Credentials ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres-secure-pass
POSTGRES_DB=ai_control_plane

REDIS_PASSWORD=redis-secure-pass

MINIO_ROOT_USER=minio-root
MINIO_ROOT_PASSWORD=minio-root-pass

# --- LLM Gateway Configurations ---
LLM_GATEWAY_URL=http://litellm:4000/v1
LLM_MODEL=llama2

# --- External LAN Physical Machines ---
# IP of the separate physical machine running Ollama on port 11434
OLLAMA_HOST_IP=192.168.1.50

# --- Authentication (Keycloak) ---
# Set these when Keycloak is deployed. Leave empty for dev header-based auth.
KEYCLOAK_JWKS_URL=
# e.g. http://iam.control-plane.local/realms/manifold/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=ai-control-plane
KEYCLOAK_ISSUER=
# e.g. http://iam.control-plane.local/realms/manifold

# --- NeMo Guardrails ---
# Leave empty to use local pattern-matching fallback
NEMO_GUARDRAILS_URL=
# e.g. http://nemo-guardrails:8080

# --- Qdrant Vector DB ---
# Leave empty to skip semantic context enrichment
QDRANT_URL=
# e.g. http://qdrant:6333
QDRANT_COLLECTION=manifold_kb

# --- MinIO Object Storage ---
MINIO_ENDPOINT=
# e.g. http://minio:9000
MINIO_ACCESS_KEY=minio-root
MINIO_SECRET_KEY=minio-root-pass
MINIO_BUCKET=manifold-evidence

# --- OpenTelemetry ---
# Leave empty to disable OTel span export
OTEL_EXPORTER_OTLP_ENDPOINT=
# e.g. http://otel-collector:4317
